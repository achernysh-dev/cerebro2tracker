        def refresh_char_data(self):
            if self.refresh_chars_Flag==True:return
            
            db=twin_plugin.examples.action.db_init()
            
            root_tasks = cerebro.core.root_tasks()
            
            proj_id = root_tasks[0].project_id()
            tags = db.project_tags(proj_id)
            tag_id = -1
            enum_name_id = -1
            for tag in tags:
                tag_name = tag[pycerebro.dbtypes.TAG_DATA_NAME] #TASK_DATA_NAME 
                if tag_name=='type': tag_id = tag[pycerebro.dbtypes.TAG_DATA_ID] 
            
            enums = db.tag_enums(tag_id)
            for enum in enums:
                enum_name = enum [pycerebro.dbtypes.TAG_ENUM_DATA_NAME]
                if enum_name=='char': enum_name_id = enum [pycerebro.dbtypes.TAG_ENUM_DATA_ID]
        
            cerebro.core.print_error('Project id ' + repr(proj_id))    
            cerebro.core.print_error('Tag id ' + repr(tag_id))
            cerebro.core.print_error('Tag value id ' + repr(enum_name_id))
            
            sql_cmd = 'select null, * from "search_Tasks"(\r\n\'{%d}\'::bigint[]\r\n, \'\r\njoin tag_val_enum as tag_e on t.uid = tag_e.taskid\'::text\r\n, \'t.flags & 0000001 = 0\r\nand \r\n(\r\n(tag_e.tagid = %d and tag_e.del = 0 and (tag_e.enumid = %d))\r\n)\'::text\r\n, 5000\r\n);'
            sql_cmd = sql_cmd%(proj_id, tag_id, enum_name_id)
            result = db.execute(sql_cmd)
#             cerebro.core.print_error(repr(result))
            
            shot_chars = [  item.cerebro_item.cerebro_path  for item in self.get_chars_from_listWidget()]
            
            for tup in result:
                task_id = tup[1]
                task = cerebro.core.task(task_id)
                parent_url = task.parent_url()
                cerebro_item = task_obj()
                cerebro_item.name =  task.name()
                cerebro_item.id =  task_id
                url = parent_url + task.name()
                cerebro_item.cerebro_path =  url
                
                self.charsLib[url] = cerebro_item

                if url in shot_chars: continue
                
                item = QListWidgetItem(task.name()) 
                item.cerebro_item = cerebro_item
                self.listWidget_chars_list.addItem(item)
                
                
            self.refresh_chars_Flag=True            
        
