        def update_shot_data(self):
            
            char_shot_items = self.get_chars_from_listWidget()
            
            dict_export = {}
            dict_export['chars']=[]
            dict_export['env']=[]
            dict_export['props']=[]
            dict_export['elements']=[]
            dict_export['description']=''
            dict_export['misc']=[]
            for i in range(len(char_shot_items)):
                item = char_shot_items[i]
                dict_val = {}
                
                for attr_k, attr_v in item.cerebro_item.__dict__.items():
                    dict_val[attr_k]=attr_v
                dict_export['chars'].append(dict_val)
            
            tags = self.current_cerebro_task.tags()
            for tag in tags:  
                cerebro.core.print_error('Tag name: ' + repr(tag.name()))      
                if tag.name()=='passport':
                    export_line = json.dumps(dict_export, indent=4, sort_keys=True)
                    cerebro.core.print_error('EXPORT LINE: ' + export_line )
                    tag.set_value(export_line)

            
