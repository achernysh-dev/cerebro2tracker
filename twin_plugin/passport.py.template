        def update_resource_chars_tasks(self, task_type = 'dyn'):
            db = twin_plugin.examples.action.db_init()
            parent_url = self.current_cerebro_task.parent_url()
            root_task_url = '/'+parent_url.split('/')[1]
            full_path_id = db.task_by_url(root_task_url)[0]
            root_task = cerebro.core.task(full_path_id)
            data = self.read_data_from_shot(root_task)
#             cerebro.core.print_error('task_type:'  + str(task_type))
#             cerebro.core.print_error('DATA from root task:'  + str(data))
            
            conn_to = []
            conn_from = []
            
            for line in data['resource_tasks']:
                name = line['name']
                cerebro_task_url = line['cerebro_path']
                connection_to = line['connection_to']
                connection_from = line['connection_from']
#                 attribs = line['attribs']
#                 cerebro.core.print_error('line["name"]'  + str(name) + ' ' + task_type)
                
                if name==task_type:
#                     cerebro.core.print_error('FOUND MATCH'  + str(name) + ' ' + task_type)
                    cerebro.core.print_error('line["name"]'  + str(name))
                    cerebro.core.print_error('line["cerebro_path"]'  + str(cerebro_task_url))
                    cerebro.core.print_error('line["connection_to"]'  + str(connection_to))
                    cerebro.core.print_error('line["connection_from"]'  + str(connection_from))
                    
                    type_task_id = db.task_by_url(cerebro_task_url)[0]
                    type_task = cerebro.core.task(type_task_id)
                    break
            
            shot_tasks = cerebro.core.task_children(self.current_cerebro_task.id())
            task_type_create = True
            for shot_task in shot_tasks: # search thru sub tasks to find the task_type
                name = shot_task.name()
                if name==task_type: 
                    task_type_create=False
                    task_copy_to_id = shot_task.id()
                if name in connection_to: conn_to.append(shot_task)
                if name in connection_from: conn_from.append(shot_task)
            
            if task_type_create==True: # if task is not created - create it 
                try: activity = type_task.activity()[0]
                except: activity=0                
                task_copy_to_id = db.add_task(self.current_cerebro_task.id(), task_type, activity)
            
            task_copy_to =  cerebro.core.task(task_copy_to_id)
            
            #get chars` names from listWidget and copy into new tasks
            items = self.get_chars_from_listWidget()
            for item in items:
                
                # find if the char has attribute for current type
                attr_data = self.read_attr_data_from_task('asset_attr', item.cerebro_item.id)
                if not task_type in attr_data: continue
                
                suffix = '_' + item. text()
                new_id = twin_plugin.examples.action.paste_task_custom([task_copy_to], [type_task_id], suffix, db)
                cerebro.core.print_error('new id'  + str(new_id))
                cerebro.core.print_error('conn_to'  + str(conn_to))
                cerebro.core.print_error('conn_from'  + str(conn_from))
                if new_id:
#                     connections = db.task_links(type_task_id) 
                    for t in conn_to:
                        first_task_id = new_id[0]
                        second_task_id = t.id()
                        db.set_link_tasks (first_task_id, second_task_id)
                    
                    for t in conn_from:
                        first_task_id = t.id()
                        second_task_id = new_id[0]
                        db.set_link_tasks (first_task_id, second_task_id)
                    
#                     twin_plugin.examples.action.set_task_to_status(new_id[0], 'ready to start')
                    
            if items: #if sub tasks created - drop connections of the main task (dyn, etc)
                connections = db.task_links(task_copy_to_id)
                for conn in connections:
                    conn_id = conn[pycerebro.dbtypes.TASK_LINK_ID] 
                    db.drop_link_tasks(conn_id)     
                    cerebro.core.print_error('Connection removed'  + str(conn_id))   
            
            self.hide()
            cerebro.gui.information_box('Success', 'OK')
            self.show()       
        
        def read_attr_data_from_task(self, tag_name, task_id):
            cerebro_task = cerebro.aclasses.Task(task_id)
            tags = cerebro_task.tags()
            for tag in tags: 
#                 tag.type() == tag.TYPE_MULTI_ENUM
                if tag.name()==tag_name: 
                    tag_value = tag.value() 
                    try:return  [attr[1] for attr in tag_value]
                    except:return []
        
