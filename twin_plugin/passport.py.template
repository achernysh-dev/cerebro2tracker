def config_read():
    if platform.system()=='Windows': config_file = 'z:/config/config.xml'

    tree = ET.parse(config_file)
    root = tree.getroot()

    dict = {}
    for child in root.attrib:
        dict[child]= root.attrib[child]
    return dict


class UpdateEvent(QEvent):
    def __init__(self, data):
        QEvent.__init__(self, QEvent.User)
        self.data = data
        
        
class itemThread(Thread, QWidget): 
    def __init__(self, parent, data=0): 
        Thread.__init__(self)
        self.parent = parent
        self.data = data
        self.start()
        

    def run(self): 
        for i in range(10):
            time.sleep(0.5)
            QApplication.postEvent(self.parent, UpdateEvent(1))


