        def read_data_from_shot(self, task=None, tagName='passport'):
            if not task: current_task = self.current_cerebro_task
            else: current_task = task 
            tags = current_task.tags()
            tag_value=None
            for tag in tags: 
                tag_name = tag.name()
                if tag_name==tagName: tag_value = tag.value()     
            try: return  json.loads(tag_value)
            except: return None
        
        def populate_shot_chars(self):
            tags = self.current_cerebro_task.tags()
            tag_value=None
            for tag in tags: 
                tag_name = tag.name()
                if tag_name=='passport': tag_value = tag.value()     
            try: data = json.loads(tag_value)
            except: cerebro.gui.information_box('Error', 'Could not read from passport attribute'); return
            
            self.listWidget_chars.clear()
            
            for char in data['chars']:
                cerebro_item = task_obj()
                cerebro_item.name =  char['name']
                cerebro_item.id =  char['id']
                cerebro_item.cerebro_path =  char['cerebro_path']
                
#                 self.charsLib[url] = cerebro_item

                item = QListWidgetItem(char['name']) 
                item.cerebro_item = cerebro_item
                self.listWidget_chars.addItem(item)                       
        
