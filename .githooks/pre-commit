#!/usr/bin/env python3
"""Reject commits that include sync_settings.json (may contain Tracker tokens)."""
import subprocess
import sys

result = subprocess.run(
    ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
    capture_output=True,
    text=True,
    check=False,
)
blocked = [
    path
    for path in result.stdout.splitlines()
    if path.endswith("sync_settings.json") and not path.endswith("sync_settings.json.example")
]
if blocked:
    print("error: sync_settings.json must not be committed (contains user tokens):")
    for path in blocked:
        print("  -", path)
    print("Settings are stored in AppData; only sync_settings.json.example belongs in git.")
    sys.exit(1)
