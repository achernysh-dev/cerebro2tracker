.env
.venv/
__pycache__/
*.pyc
tracker_structure.json

# Vendored deps are committed; ignore only generated bytecode inside vendor/.
vendor/site-packages/**/__pycache__/
vendor/site-packages/**/*.pyc

# User sync config (tokens, task map). Stored in AppData; ignore any copy in the repo.
**/sync_settings.json
!**/sync_settings.json.example
